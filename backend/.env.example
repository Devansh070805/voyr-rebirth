# ─── Voyr Backend — Environment Variables ──────────────────────────────────
# Copy: cp backend/.env.example backend/.env
#
# Required: DATABASE_URL (Supabase Postgres), JWT_SECRET, REDIS_URL,
# DEEPSEEK_API_KEY, RESEND_API_KEY. PAYMENT_MODE=mock needs no Razorpay keys.

# ─── Supabase (project reference) ────────────────────────────────────────────
SUPABASE_PROJECT_REF=your-project-ref
SUPABASE_URL=https://your-project-ref.supabase.co
# Server-only — never expose in frontend
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key

# ─── Database — Supabase Postgres (required) ───────────────────────────────────
# Supabase → Database → URI (direct :5432 or session pooler :6543)
# Windows local: set SUPABASE_POOLER_REGION (from Session pooler in dashboard) so
# migrate:up rewrites direct db.* URLs to the pooler automatically.
# Or paste the full session pooler URI as DATABASE_URL (port 6543).
# Auto-detect region: node scripts/detect-pooler-region.mjs
DATABASE_URL=postgresql://postgres.your-project-ref:YOUR_SUPABASE_DB_PASSWORD@aws-0-your-region.pooler.supabase.com:6543/postgres
# DATABASE_URL=postgresql://postgres:YOUR_SUPABASE_DB_PASSWORD@db.your-project-ref.supabase.co:5432/postgres
SUPABASE_POOLER_REGION=ap-southeast-2
SUPABASE_POOLER_PREFIX=aws-0
# DB_USE_SUPABASE_POOLER=true
DB_SSL=true
# DB_POOL_MAX=20
# DB_IDLE_TIMEOUT=30000
# DB_CONNECT_TIMEOUT=5000

# ─── Server ───────────────────────────────────────────────────────────────────
PORT=3001
NODE_ENV=development
CORS_ORIGIN=http://localhost:3000
FRONTEND_URL=http://localhost:3000

# ─── Redis (required in production; recommended for OTP/rate limits) ─────────
REDIS_URL=redis://127.0.0.1:6379
# REDIS_REQUIRED=true

# ─── Authentication (required) ───────────────────────────────────────────────
JWT_SECRET=your-jwt-secret-change-in-production
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d
OTP_EXPIRY_MINUTES=10
# DEV_LOG_OTP=true  # local only — logs OTP to console when RESEND_API_KEY is unset

# Google OAuth — optional (backend route exists; frontend is OTP-only)
# NEXT_PUBLIC_GOOGLE_CLIENT_ID=your-google-oauth-client-id.apps.googleusercontent.com

# ─── Admin (/admin/ops, /travel-visa/admin) ───────────────────────────────────
ADMIN_EMAILS=you@example.com
# ADMIN_USER_IDS=uuid1,uuid2

# ─── AI — default: DeepSeek (OpenAI-compatible API) ───────────────────────────
AI_PROVIDER=deepseek
DEEPSEEK_API_KEY=sk-your-deepseek-api-key
DEEPSEEK_MODEL=deepseek-v4-flash
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1

# AI_PROVIDER=openai
# OPENAI_API_KEY=sk-your-openai-api-key
# OPENAI_MODEL=gpt-4o
# OPENAI_BASE_URL=https://api.openai.com/v1

# AI_PROVIDER=anthropic
# ANTHROPIC_API_KEY=sk-ant-your-anthropic-api-key
# ANTHROPIC_MODEL=claude-sonnet-4-20250514

# AI_PROVIDER=openrouter
# OPENROUTER_API_KEY=sk-or-v1-your-openrouter-key
# OPENROUTER_MODEL=inclusionai/ring-2.6-1t:free

# ─── Payments ────────────────────────────────────────────────────────────────
PAYMENT_MODE=mock
PAYMENT_MOCK_WEBHOOK_SECRET=voyr-mock-webhook-dev
PAYMENT_WEBHOOK_SECRET=your-razorpay-webhook-secret
PAYMENT_CHECKOUT_BASE_URL=https://checkout.razorpay.com/pay

# ─── Email (OTP + booking notifications) ─────────────────────────────────────
RESEND_API_KEY=re_your-resend-api-key
# Test sender: only delivers to your Resend signup email. For production, verify a
# domain at resend.com/domains and set EMAIL_FROM to e.g. noreply@yourdomain.com
EMAIL_FROM=onboarding@resend.dev
EMAIL_FROM_NAME=Voyr

# ─── Cloudflare R2 (documents — optional in dev) ────────────────────────────
# R2 → bucket → Settings → S3 API: endpoint + Access Key ID + Secret Access Key
R2_ACCOUNT_ID=your-cloudflare-account-id
R2_BUCKET_NAME=voyr
R2_ENDPOINT=https://your-account-id.r2.cloudflarestorage.com
R2_ACCESS_KEY_ID=your-r2-access-key-id
R2_SECRET_ACCESS_KEY=your-r2-secret-access-key
# Optional: Cloudflare API token (cfat_...) for Wrangler — not used for S3 uploads
R2_CLOUDFLARE_API_TOKEN=your-cloudflare-api-token
# Public URL for generated PDF links (R2.dev subdomain or custom domain)
R2_PUBLIC_URL=https://your-public-r2-url

# ─── Queues (optional) ───────────────────────────────────────────────────────
# QUEUE_URL=https://your-queue-consumer.example/publish
# DEAD_LETTER_QUEUE_URL=https://your-dlq-consumer.example/publish

# ─── External data APIs (optional) ─────────────────────────────────────────────
GEOAPIFY_API_KEY=your-geoapify-api-key
MAKCORPS_API_KEY=your-makcorps-api-key
AVIATION_STACK_API_KEY=your-aviation-stack-api-key
TINYFISH_API_KEY=sk-tinyfish-your-api-key

# ─── Quote pricing (optional) ──────────────────────────────────────────────────
# QUOTE_TAX_RATE=0.18
# QUOTE_MARKUP_RATE=0.10
# QUOTE_FEE_FLAT=500
# QUOTE_DISCOUNT_RATE=0
# QUOTE_VALIDITY_HOURS=48

# ─── Observability ───────────────────────────────────────────────────────────
LOG_LEVEL=info
# Required in production — protects GET /metrics (Authorization: Bearer <token>)
METRICS_TOKEN=generate-a-long-random-token-for-metrics
SENTRY_DSN=https://your-key@o000000.ingest.us.sentry.io/0000000
ALERT_BOOKING_PENDING_THRESHOLD_MS=3600000
ALERT_QUEUE_BACKLOG_THRESHOLD=100
ALERT_CHECK_INTERVAL_MS=60000
