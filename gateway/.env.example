# ─── Voyr Gateway (Cloudflare Worker) ─────────────────────────────────────
# Local: cp gateway/.env.example gateway/.dev.vars
#
# Wrangler loads .dev.vars for `npm run dev:gateway`.
# Production:
#   JWT_SECRET → npx wrangler secret put JWT_SECRET
#   BACKEND_ORIGIN → gateway/wrangler.toml [vars] (Railway URL)

BACKEND_ORIGIN=http://localhost:3001
JWT_SECRET=your-jwt-secret-change-in-production
CORS_ORIGIN=http://localhost:3000
