# ─── Voyr Frontend — Environment Variables ───────────────────────────────
# Copy: cp frontend/.env.example frontend/.env.local
#
# Production: Cloudflare Pages → Settings → Environment variables.
# NEXT_PUBLIC_* vars are embedded in the client bundle.

# ─── API ──────────────────────────────────────────────────────────────────────
# With gateway (recommended locally):
NEXT_PUBLIC_API_URL=http://127.0.0.1:8787
# Backend only:
# NEXT_PUBLIC_API_URL=http://localhost:3001
# Production Worker URL:
# NEXT_PUBLIC_API_URL=https://voyr-travel-ops.your-subdomain.workers.dev

NEXT_PUBLIC_APP_URL=http://localhost:3000

# ─── Supabase (client + SSR middleware) ─────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_your-publishable-key

# Optional — Google OAuth (UI not shipped):
# NEXT_PUBLIC_GOOGLE_CLIENT_ID=your-google-oauth-client-id.apps.googleusercontent.com

# ─── Mapbox (optional — TripMap placeholder if unset) ─────────────────────────
# NEXT_PUBLIC_MAPBOX_TOKEN=your-mapbox-public-token

# ─── Sentry (optional) ─────────────────────────────────────────────────────────
NEXT_PUBLIC_SENTRY_DSN=https://your-key@o000000.ingest.us.sentry.io/0000000
SENTRY_ORG=your-sentry-org
SENTRY_PROJECT=your-sentry-project
# SENTRY_AUTH_TOKEN=  # CI only — source maps

# SENTRY_SUPPRESS_INSTRUMENTATION_FILE_WARNING=1
# SENTRY_SUPPRESS_GLOBAL_ERROR_HANDLER_FILE_WARNING=1
