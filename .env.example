# ─── Voyr monorepo — environment index (placeholders only) ─────────────────
# The backend loads backend/.env only. Use the per-app files below.
#
#   cp backend/.env.example   backend/.env
#   cp frontend/.env.example  frontend/.env.local
#   cp gateway/.env.example   gateway/.dev.vars
#
# Full backend reference: backend/.env.example

# ═══ backend/.env ═══════════════════════════════════════════════════════════
SUPABASE_PROJECT_REF=your-project-ref
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key
DATABASE_URL=postgresql://postgres:YOUR_SUPABASE_DB_PASSWORD@db.your-project-ref.supabase.co:5432/postgres
DB_SSL=true
PORT=3001
NODE_ENV=development
CORS_ORIGIN=http://localhost:3000
FRONTEND_URL=http://localhost:3000
REDIS_URL=redis://127.0.0.1:6379
JWT_SECRET=your-jwt-secret-change-in-production
# Optional — Google OAuth (backend route only; UI ships OTP-only):
# NEXT_PUBLIC_GOOGLE_CLIENT_ID=your-google-oauth-client-id.apps.googleusercontent.com
ADMIN_EMAILS=you@example.com
AI_PROVIDER=deepseek
DEEPSEEK_API_KEY=sk-your-deepseek-api-key
DEEPSEEK_MODEL=deepseek-v4-flash
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1
PAYMENT_MODE=mock
PAYMENT_MOCK_WEBHOOK_SECRET=voyr-mock-webhook-dev
PAYMENT_WEBHOOK_SECRET=your-razorpay-webhook-secret
RESEND_API_KEY=re_your-resend-api-key
EMAIL_FROM=Voyr <onboarding@resend.dev>
TINYFISH_API_KEY=sk-tinyfish-your-api-key
GEOAPIFY_API_KEY=your-geoapify-api-key
MAKCORPS_API_KEY=your-makcorps-api-key
AVIATION_STACK_API_KEY=your-aviation-stack-api-key
SENTRY_DSN=https://your-key@o000000.ingest.us.sentry.io/0000000
LOG_LEVEL=info

# ═══ frontend/.env.local ════════════════════════════════════════════════════
# NEXT_PUBLIC_API_URL=http://127.0.0.1:8787
# NEXT_PUBLIC_APP_URL=http://localhost:3000
# NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
# NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_your-key
# Optional — Google OAuth (UI not shipped):
# NEXT_PUBLIC_GOOGLE_CLIENT_ID=your-google-oauth-client-id.apps.googleusercontent.com
# NEXT_PUBLIC_MAPBOX_TOKEN=your-mapbox-public-token
# NEXT_PUBLIC_SENTRY_DSN=https://your-key@o000000.ingest.us.sentry.io/0000000

# ═══ gateway/.dev.vars ═══════════════════════════════════════════════════════
# BACKEND_ORIGIN=http://localhost:3001
# JWT_SECRET=<same as backend JWT_SECRET>
# Production BACKEND_ORIGIN is in gateway/wrangler.toml (Railway URL)
